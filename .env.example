# AI provider credentials for core/ai_provider.py (one-shot text calls only,
# e.g. actions/dev_agent.py). Does NOT affect the Gemini Live voice session
# in main.py / actions/screen_processor.py, which is configured separately
# via config/api_keys.json.
#
# Option A — Gemini (used if no LLM_* trio below is set):
GEMINI_API_KEY=

# Option B — any OpenAI-compatible endpoint (local server, OpenAI, etc.).
# Takes priority over GEMINI_API_KEY when all three are set.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
